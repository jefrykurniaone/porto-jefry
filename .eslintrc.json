{
  "extends": ["next/core-web-vitals", "next/typescript"],
  "plugins": ["sonarjs"],
  "rules": {
    "max-lines": ["error", 300],
    "max-lines-per-function": ["error", 40],
    "sonarjs/no-nested-template-literals": "error"
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.test.tsx"],
      "rules": {
        "max-lines": "off",
        "max-lines-per-function": "off"
      }
    }
  ]
}
