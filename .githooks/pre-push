#!/bin/sh
# pre-push hook: prevent direct pushes to main/master
# All changes must go through a feature branch and Pull Request.
#
# Branch naming convention: feat/, fix/, chore/, hotfix/
# See .github/copilot-instructions.md for full Git & Collaboration standards.

PROTECTED_BRANCHES="^(main|master)$"

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

if echo "$CURRENT_BRANCH" | grep -qE "$PROTECTED_BRANCHES"; then
    echo ""
    echo "  Direct push to '$CURRENT_BRANCH' is not allowed."
    echo ""
    echo "  Create a feature branch first:"
    echo "    git checkout -b feat/<description>"
    echo "    git checkout -b fix/<description>"
    echo "    git checkout -b chore/<description>"
    echo ""
    echo "  Then open a Pull Request to merge into $CURRENT_BRANCH."
    echo ""
    exit 1
fi

exit 0
